:acne a :Disease ;
    :description "Acne vulgaris is the formation of comedones, papules, pustules, nodules, and/or cysts as a result of obstruction and inflammation of pilosebaceous units (hair follicles and their accompanying sebaceous gland). Acne develops on the face and upper trunk. It most often affects adolescents."^^xsd:string ;
    :hasSymptom :blackheads,
        :pus_filled_pimples,
        :scurring,
        :skin_rash ;
    :hasTreatment :avoid_fatty_spicy_food,
        :avoid_too_many_products,
        :bath_twice,
        :drink_plenty_of_water .

:aids a :Disease ;
    :description "Acquired immunodeficiency syndrome (AIDS) is a chronic, potentially life-threatening condition caused by the human immunodeficiency virus (HIV). By damaging your immune system, HIV interferes with your body's ability to fight infection and disease."^^xsd:string ;
    :hasSymptom :extra_marital_contacts,
        :high_fever,
        :muscle_wasting,
        :patches_in_throat ;
    :hasTreatment :avoid_open_cuts,
        :consult_doctor,
        :follow_up,
        :wear_ppe_if_possible .

:alcoholic_hepatitis a :Disease ;
    :description "Alcoholic hepatitis is a diseased, inflammatory condition of the liver caused by heavy alcohol consumption over an extended period of time. It's also aggravated by binge drinking and ongoing alcohol use. If you develop this condition, you must stop drinking alcohol"^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :distention_of_abdomen,
        :fluid_overload,
        :history_of_alcohol_consumption,
        :swelling_of_stomach,
        :vomiting,
        :yellowish_skin ;
    :hasTreatment :consult_doctor,
        :follow_up,
        :medication,
        :stop_alcohol_consumption .

:allergy a :Disease ;
    :description "An allergy is an immune system response to a foreign substance that's not typically harmful to your body.They can include certain foods, pollen, or pet dander. Your immune system's job is to keep you healthy by fighting harmful pathogens."^^xsd:string ;
    :hasSymptom :chills,
        :continuous_sneezing,
        :shivering,
        :watering_from_eyes ;
    :hasTreatment :apply_calamine,
        :cover_area_with_bandage,
        :use_ice_to_compress_itching .

:arthritis a :Disease ;
    :description "Arthritis is the swelling and tenderness of one or more of your joints. The main symptoms of arthritis are joint pain and stiffness, which typically worsen with age. The most common types of arthritis are osteoarthritis and rheumatoid arthritis."^^xsd:string ;
    :hasSymptom :movement_stiffness,
        :muscle_weakness,
        :painful_walking,
        :stiff_neck,
        :swelling_joints ;
    :hasTreatment :exercise,
        :massage,
        :try_acupuncture,
        :use_hot_and_cold_therapy .

:bronchial_asthma a :Disease ;
    :description "Bronchial asthma is a medical condition which causes the airway path of the lungs to swell and narrow. Due to this swelling, the air path produces excess mucus making it hard to breathe, which results in coughing, short breath, and wheezing. The disease is chronic and interferes with daily working."^^xsd:string ;
    :hasSymptom :breathlessness,
        :cough,
        :family_history,
        :fatigue,
        :high_fever,
        :mucoid_sputum ;
    :hasTreatment :get_away_from_trigger,
        :seek_help,
        :switch_to_loose_cloothing,
        :take_deep_breaths .

:cervical_spondylosis a :Disease ;
    :description "Cervical spondylosis is a general term for age-related wear and tear affecting the spinal disks in your neck. As the disks dehydrate and shrink, signs of osteoarthritis develop, including bony projections along the edges of bones (bone spurs)."^^xsd:string ;
    :hasSymptom :back_pain,
        :dizziness,
        :loss_of_balance,
        :neck_pain,
        :weakness_in_limbs ;
    :hasTreatment :consult_doctor,
        :exercise,
        :take_otc_pain_reliver,
        :use_heating_pad_or_cold_pack .

:chicken_pox a :Disease ;
    :description "Chickenpox is a highly contagious disease caused by the varicella-zoster virus (VZV). It can cause an itchy, blister-like rash. The rash first appears on the chest, back, and face, and then spreads over the entire body, causing between 250 and 500 itchy blisters."^^xsd:string ;
    :hasSymptom :fatigue,
        :headache,
        :high_fever,
        :itching,
        :lethargy,
        :loss_of_appetite,
        :malaise,
        :mild_fever,
        :red_spots_over_body,
        :skin_rash,
        :swelled_lymph_nodes ;
    :hasTreatment :avoid_public_places,
        :consume_neem_leaves,
        :take_vaccine,
        :use_neem_in_bathing .

:chronic_cholestasis a :Disease ;
    :description "Chronic cholestatic diseases, whether occurring in infancy, childhood or adulthood, are characterized by defective bile acid transport from the liver to the intestine, which is caused by primary damage to the biliary epithelium in most cases"^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :itching,
        :loss_of_appetite,
        :nausea,
        :vomiting,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :anti_itch_medicine,
        :cold_baths,
        :consult_doctor,
        :eat_healthy .

:common_cold a :Disease ;
    :description "The common cold is a viral infection of your nose and throat (upper respiratory tract). It's usually harmless, although it might not feel that way. Many types of viruses can cause a common cold."^^xsd:string ;
    :hasSymptom :chest_pain,
        :chills,
        :congestion,
        :continuous_sneezing,
        :cough,
        :fatigue,
        :headache,
        :high_fever,
        :loss_of_smell,
        :malaise,
        :muscle_pain,
        :phlegm,
        :redness_of_eyes,
        :runny_nose,
        :sinus_pressure,
        :swelled_lymph_nodes,
        :throat_irritation ;
    :hasTreatment :avoid_cold_food,
        :drink_vitamin_c_rich_drinks,
        :keep_fever_in_check,
        :take_vapour .

:dengue a :Disease ;
    :description "an acute infectious disease caused by a flavivirus (species Dengue virus of the genus Flavivirus), transmitted by aedes mosquitoes, and characterized by headache, severe joint pain, and a rash. — called also breakbone fever, dengue fever."^^xsd:string ;
    :hasSymptom :back_pain,
        :chills,
        :fatigue,
        :headache,
        :high_fever,
        :joint_pain,
        :loss_of_appetite,
        :malaise,
        :muscle_pain,
        :nausea,
        :pain_behind_the_eyes,
        :red_spots_over_body,
        :skin_rash,
        :vomiting ;
    :hasTreatment :avoid_fatty_spicy_food,
        :drink_papaya_leaf_juice,
        :keep_hydrated,
        :keep_mosquitos_away .

:description a owl:DatatypeProperty ;
    rdfs:domain :Disease ;
    rdfs:range xsd:string .

:diabetes a :Disease ;
    :description "Diabetes is a disease that occurs when your blood glucose, also called blood sugar, is too high. Blood glucose is your main source of energy and comes from the food you eat. Insulin, a hormone made by the pancreas, helps glucose from food get into your cells to be used for energy."^^xsd:string ;
    :hasSymptom :blurred_and_distorted_vision,
        :excessive_hunger,
        :fatigue,
        :increased_appetite,
        :irregular_sugar_level,
        :lethargy,
        :obesity,
        :polyuria,
        :restlessness,
        :weight_loss ;
    :hasTreatment :consult_doctor,
        :exercise,
        :follow_up,
        :have_balanced_diet .

:dimorphic_hemorrhoidspiles a :Disease ;
    :description "Hemorrhoids, also spelled haemorrhoids, are vascular structures in the anal canal. In their ... Other names, Haemorrhoids, piles, hemorrhoidal disease ."^^xsd:string ;
    :hasSymptom :bloody_stool,
        :constipation,
        :irritation_in_anus,
        :pain_during_bowel_movements,
        :pain_in_anal_region ;
    :hasTreatment :avoid_fatty_spicy_food,
        :consume_alovera_juice,
        :consume_witch_hazel,
        :warm_bath_with_epsom_salt .

:drug_reaction a :Disease ;
    :description "An adverse drug reaction (ADR) is an injury caused by taking medication. ADRs may occur following a single dose or prolonged administration of a drug or result from the combination of two or more drugs."^^xsd:string ;
    :hasSymptom :burning_micturition,
        :itching,
        :skin_rash,
        :spotting_urination,
        :stomach_pain ;
    :hasTreatment :consult_nearest_hospital,
        :follow_up,
        :stop_irritation,
        :stop_taking_drug .

:exhibitsSymptom a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :Symptom .

:fungal_infection a :Disease ;
    :description "In humans, fungal infections occur when an invading fungus takes over an area of the body and is too much for the immune system to handle. Fungi can live in the air, soil, water, and plants. There are also some fungi that live naturally in the human body. Like many microbes, there are helpful fungi and harmful fungi."^^xsd:string ;
    :hasSymptom :dischromic_patches,
        :itching,
        :nodal_skin_eruptions,
        :skin_rash ;
    :hasTreatment :bath_twice,
        :keep_infected_area_dry,
        :use_clean_cloths,
        :use_detol_or_neem_in_bathing_water .

:gastroenteritis a :Disease ;
    :description "Gastroenteritis is an inflammation of the digestive tract, particularly the stomach, and large and small intestines. Viral and bacterial gastroenteritis are intestinal infections associated with symptoms of diarrhea , abdominal cramps, nausea , and vomiting ."^^xsd:string ;
    :hasSymptom :dehydration,
        :diarrhoea,
        :sunken_eyes,
        :vomiting ;
    :hasTreatment :ease_back_into_eating,
        :rest,
        :stop_eating_solid_food_for_while,
        :try_taking_small_sips_of_water .

:gerd a :Disease ;
    :description "Gastroesophageal reflux disease, or GERD, is a digestive disorder that affects the lower esophageal sphincter (LES), the ring of muscle between the esophagus and stomach. Many people, including pregnant women, suffer from heartburn or acid indigestion caused by GERD."^^xsd:string ;
    :hasSymptom :acidity,
        :chest_pain,
        :cough,
        :stomach_pain,
        :ulcers_on_tongue,
        :vomiting ;
    :hasTreatment :avoid_fatty_spicy_food,
        :avoid_lying_down_after_eating,
        :exercise,
        :maintain_healthy_weight .

:hasDisease a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :Disease .

:hasSymptom a owl:ObjectProperty ;
    rdfs:domain :Disease ;
    rdfs:range :Symptom .

:hasTreatment a owl:ObjectProperty ;
    rdfs:domain :Disease ;
    rdfs:range :Treatment .

:heart_attack a :Disease ;
    :description "The death of heart muscle due to the loss of blood supply. The loss of blood supply is usually caused by a complete blockage of a coronary artery, one of the arteries that supplies blood to the heart muscle."^^xsd:string ;
    :hasSymptom :breathlessness,
        :chest_pain,
        :sweating,
        :vomiting ;
    :hasTreatment :call_ambulance,
        :chew_or_swallow_asprin,
        :keep_calm .

:hepatitis_a a :Disease ;
    :description "Hepatitis A is a highly contagious liver infection caused by the hepatitis A virus. The virus is one of several types of hepatitis viruses that cause inflammation and affect your liver's ability to function."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :dark_urine,
        :diarrhoea,
        :joint_pain,
        :loss_of_appetite,
        :mild_fever,
        :muscle_pain,
        :nausea,
        :vomiting,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :avoid_fatty_spicy_food,
        :consult_nearest_hospital,
        :medication,
        :wash_hands_through .

:hepatitis_b a :Disease ;
    :description "Hepatitis B is an infection of your liver. It can cause scarring of the organ, liver failure, and cancer. It can be fatal if it isn't treated. It's spread when people come in contact with the blood, open sores, or body fluids of someone who has the hepatitis B virus."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :dark_urine,
        :fatigue,
        :itching,
        :lethargy,
        :loss_of_appetite,
        :malaise,
        :receiving_blood_transfusion,
        :receiving_unsterile_injections,
        :yellow_urine,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :consult_nearest_hospital,
        :eat_healthy,
        :medication,
        :vaccination .

:hepatitis_c a :Disease ;
    :description "Inflammation of the liver due to the hepatitis C virus (HCV), which is usually spread via blood transfusion (rare), hemodialysis, and needle sticks. The damage hepatitis C does to the liver can lead to cirrhosis and its complications as well as cancer."^^xsd:string ;
    :hasSymptom :family_history,
        :fatigue,
        :loss_of_appetite,
        :nausea,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :consult_nearest_hospital,
        :eat_healthy,
        :medication,
        :vaccination .

:hepatitis_d a :Disease ;
    :description "Hepatitis D, also known as the hepatitis delta virus, is an infection that causes the liver to become inflamed. This swelling can impair liver function and cause long-term liver problems, including liver scarring and cancer. The condition is caused by the hepatitis D virus (HDV)."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :dark_urine,
        :fatigue,
        :joint_pain,
        :loss_of_appetite,
        :nausea,
        :vomiting,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :consult_doctor,
        :eat_healthy,
        :follow_up,
        :medication .

:hepatitis_e a :Disease ;
    :description "A rare form of liver inflammation caused by infection with the hepatitis E virus (HEV). It is transmitted via food or drink handled by an infected person or through infected water supplies in areas where fecal matter may get into the water. Hepatitis E does not cause chronic liver disease."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :acute_liver_failure,
        :coma,
        :dark_urine,
        :fatigue,
        :high_fever,
        :joint_pain,
        :loss_of_appetite,
        :nausea,
        :stomach_bleeding,
        :vomiting,
        :yellowing_of_eyes,
        :yellowish_skin ;
    :hasTreatment :consult_doctor,
        :medication,
        :rest,
        :stop_alcohol_consumption .

:hypertension a :Disease ;
    :description "Hypertension (HTN or HT), also known as high blood pressure (HBP), is a long-term medical condition in which the blood pressure in the arteries is persistently elevated. High blood pressure typically does not cause symptoms."^^xsd:string ;
    :hasSymptom :chest_pain,
        :dizziness,
        :headache,
        :lack_of_concentration,
        :loss_of_balance ;
    :hasTreatment :get_proper_sleep,
        :meditation,
        :reduce_stress,
        :salt_baths .

:hyperthyroidism a :Disease ;
    :description "Hyperthyroidism (overactive thyroid) occurs when your thyroid gland produces too much of the hormone thyroxine. Hyperthyroidism can accelerate your body's metabolism, causing unintentional weight loss and a rapid or irregular heartbeat."^^xsd:string ;
    :hasSymptom :abnormal_menstruation,
        :diarrhoea,
        :excessive_hunger,
        :fast_heart_rate,
        :fatigue,
        :irritability,
        :mood_swings,
        :muscle_weakness,
        :restlessness,
        :sweating,
        :weight_loss ;
    :hasTreatment :eat_healthy,
        :massage,
        :take_radioactive_iodine_treatment,
        :use_lemon_balm .

:hypoglycemia a :Disease ;
    :description "Hypoglycemia is a condition in which your blood sugar (glucose) level is lower than normal. Glucose is your body's main energy source. Hypoglycemia is often related to diabetes treatment. But other drugs and a variety of conditions — many rare — can cause low blood sugar in people who don't have diabetes."^^xsd:string ;
    :hasSymptom :anxiety,
        :blurred_and_distorted_vision,
        :drying_and_tingling_lips,
        :excessive_hunger,
        :fatigue,
        :headache,
        :irritability,
        :nausea,
        :palpitations,
        :slurred_speech,
        :sweating,
        :vomiting ;
    :hasTreatment :check_in_pulse,
        :consult_doctor,
        :drink_sugary_drinks,
        :lie_down_on_side .

:hypothyroidism a :Disease ;
    :description "Hypothyroidism, also called underactive thyroid or low thyroid, is a disorder of the endocrine system in which the thyroid gland does not produce enough thyroid hormone."^^xsd:string ;
    :hasSymptom :abnormal_menstruation,
        :brittle_nails,
        :cold_hands_and_feets,
        :depression,
        :dizziness,
        :enlarged_thyroid,
        :fatigue,
        :irritability,
        :lethargy,
        :mood_swings,
        :puffy_face_and_eyes,
        :swollen_extremeties,
        :weight_gain ;
    :hasTreatment :eat_healthy,
        :exercise,
        :get_proper_sleep,
        :reduce_stress .

:impetigo a :Disease ;
    :description "Impetigo (im-puh-TIE-go) is a common and highly contagious skin infection that mainly affects infants and children. Impetigo usually appears as red sores on the face, especially around a child's nose and mouth, and on hands and feet. The sores burst and develop honey-colored crusts."^^xsd:string ;
    :hasSymptom :blister,
        :high_fever,
        :red_sore_around_nose,
        :skin_rash,
        :yellow_crust_ooze ;
    :hasTreatment :consult_doctor,
        :remove_scabs_with_wet_compressed_cloth,
        :soak_affected_area_in_warm_water,
        :use_antibiotics .

:jaundice a :Disease ;
    :description "Yellow staining of the skin and sclerae (the whites of the eyes) by abnormally high blood levels of the bile pigment bilirubin. The yellowing extends to other tissues and body fluids. Jaundice was once called the \"morbus regius\" (the regal disease) in the belief that only the touch of a king could cure it"^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :dark_urine,
        :fatigue,
        :high_fever,
        :itching,
        :vomiting,
        :weight_loss,
        :yellowish_skin ;
    :hasTreatment :consume_milk_thistle,
        :drink_plenty_of_water,
        :eat_fruits_and_high_fiberous_food,
        :medication .

:malaria a :Disease ;
    :description "An infectious disease caused by protozoan parasites from the Plasmodium family that can be transmitted by the bite of the Anopheles mosquito or by a contaminated needle or transfusion. Falciparum malaria is the most deadly type."^^xsd:string ;
    :hasSymptom :chills,
        :diarrhoea,
        :headache,
        :high_fever,
        :muscle_pain,
        :nausea,
        :sweating,
        :vomiting ;
    :hasTreatment :avoid_non_veg_food,
        :avoid_oily_food,
        :consult_nearest_hospital,
        :keep_mosquitos_out .

:migraine a :Disease ;
    :description "A migraine can cause severe throbbing pain or a pulsing sensation, usually on one side of the head. It's often accompanied by nausea, vomiting, and extreme sensitivity to light and sound. Migraine attacks can last for hours to days, and the pain can be so severe that it interferes with your daily activities."^^xsd:string ;
    :hasSymptom :acidity,
        :blurred_and_distorted_vision,
        :depression,
        :excessive_hunger,
        :headache,
        :indigestion,
        :irritability,
        :stiff_neck,
        :visual_disturbances ;
    :hasTreatment :consult_doctor,
        :meditation,
        :reduce_stress,
        :use_poloroid_glasses_in_sun .

:name a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:string .

:osteoarthristis a :Disease ;
    :description "Osteoarthritis is the most common form of arthritis, affecting millions of people worldwide. It occurs when the protective cartilage that cushions the ends of your bones wears down over time."^^xsd:string ;
    :hasSymptom :hip_joint_pain,
        :joint_pain,
        :knee_pain,
        :neck_pain,
        :painful_walking,
        :swelling_joints ;
    :hasTreatment :acetaminophen,
        :consult_nearest_hospital,
        :follow_up,
        :salt_baths .

:paralysis_brain_hemorrhage a :Disease ;
    :description "Intracerebral hemorrhage (ICH) is when blood suddenly bursts into brain tissue, causing damage to your brain. Symptoms usually appear suddenly during ICH. They include headache, weakness, confusion, and paralysis, particularly on one side of your body."^^xsd:string ;
    :hasSymptom :altered_sensorium,
        :headache,
        :vomiting,
        :weakness_of_one_body_side ;
    :hasTreatment :consult_doctor,
        :eat_healthy,
        :exercise,
        :massage .

:peptic_ulcer_diseae a :Disease ;
    :description "Peptic ulcer disease (PUD) is a break in the inner lining of the stomach, the first part of the small intestine, or sometimes the lower esophagus. An ulcer in the stomach is called a gastric ulcer, while one in the first part of the intestines is a duodenal ulcer."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :indigestion,
        :internal_itching,
        :loss_of_appetite,
        :passage_of_gases,
        :vomiting ;
    :hasTreatment :avoid_fatty_spicy_food,
        :consume_probiotic_food,
        :eliminate_milk,
        :limit_alcohol .

:pneumonia a :Disease ;
    :description "Pneumonia is an infection in one or both lungs. Bacteria, viruses, and fungi cause it. The infection causes inflammation in the air sacs in your lungs, which are called alveoli. The alveoli fill with fluid or pus, making it difficult to breathe."^^xsd:string ;
    :hasSymptom :breathlessness,
        :chest_pain,
        :chills,
        :cough,
        :fast_heart_rate,
        :fatigue,
        :high_fever,
        :malaise,
        :phlegm,
        :rusty_sputum,
        :sweating ;
    :hasTreatment :consult_doctor,
        :follow_up,
        :medication,
        :rest .

:psoriasis a :Disease ;
    :description "Psoriasis is a common skin disorder that forms thick, red, bumpy patches covered with silvery scales. They can pop up anywhere, but most appear on the scalp, elbows, knees, and lower back. Psoriasis can't be passed from person to person. It does sometimes happen in members of the same family."^^xsd:string ;
    :hasSymptom :inflammatory_nails,
        :joint_pain,
        :silver_like_dusting,
        :skin_peeling,
        :skin_rash,
        :small_dents_in_nails ;
    :hasTreatment :consult_doctor,
        :salt_baths,
        :stop_bleeding_using_pressure,
        :wash_hands_with_warm_soapy_water .

:receivesTreatment a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :Treatment .

:tuberculosis a :Disease ;
    :description "Tuberculosis (TB) is an infectious disease usually caused by Mycobacterium tuberculosis (MTB) bacteria. Tuberculosis generally affects the lungs, but can also affect other parts of the body. Most infections show no symptoms, in which case it is known as latent tuberculosis."^^xsd:string ;
    :hasSymptom :blood_in_sputum,
        :breathlessness,
        :chest_pain,
        :chills,
        :cough,
        :fatigue,
        :high_fever,
        :loss_of_appetite,
        :malaise,
        :mild_fever,
        :phlegm,
        :sweating,
        :swelled_lymph_nodes,
        :vomiting,
        :weight_loss,
        :yellowing_of_eyes ;
    :hasTreatment :consult_doctor,
        :cover_mouth,
        :medication,
        :rest .

:typhoid a :Disease ;
    :description "An acute illness characterized by fever caused by infection with the bacterium Salmonella typhi. Typhoid fever has an insidious onset, with fever, headache, constipation, malaise, chills, and muscle pain. Diarrhea is uncommon, and vomiting is not usually severe."^^xsd:string ;
    :hasSymptom :abdominal_pain,
        :belly_pain,
        :chills,
        :constipation,
        :diarrhoea,
        :fatigue,
        :headache,
        :high_fever,
        :nausea,
        :toxic_look_typhos,
        :vomiting ;
    :hasTreatment :antiboitic_therapy,
        :consult_doctor,
        :eat_high_calorie_vegitables,
        :medication .

:urinary_tract_infection a :Disease ;
    :description "Urinary tract infection: An infection of the kidney, ureter, bladder, or urethra. Abbreviated UTI. Not everyone with a UTI has symptoms, but common symptoms include a frequent urge to urinate and pain or burning when urinating."^^xsd:string ;
    :hasSymptom :bladder_discomfort,
        :burning_micturition,
        :continuous_feel_of_urine,
        :foul_smell_of_urine ;
    :hasTreatment :drink_cranberry_juice,
        :drink_plenty_of_water,
        :increase_vitamin_c_intake,
        :take_probiotics .

:varicose_veins a :Disease ;
    :description "A vein that has enlarged and twisted, often appearing as a bulging, blue blood vessel that is clearly visible through the skin. Varicose veins are most common in older adults, particularly women, and occur especially on the legs."^^xsd:string ;
    :hasSymptom :bruising,
        :cramps,
        :fatigue,
        :obesity,
        :prominent_veins_on_calf,
        :swollen_blood_vessels,
        :swollen_legs ;
    :hasTreatment :dont_stand_still_for_long,
        :lie_down_flat_and_raise_the_leg_high,
        :use_oinments,
        :use_vein_compression .

:vertigo_paroymsal_positional_vertigo a :Disease ;
    :description "Benign paroxysmal positional vertigo (BPPV) is one of the most common causes of vertigo — the sudden sensation that you're spinning or that the inside of your head is spinning. Benign paroxysmal positional vertigo causes brief episodes of mild to intense dizziness."^^xsd:string ;
    :hasSymptom :headache,
        :loss_of_balance,
        :nausea,
        :spinning_movements,
        :unsteadiness,
        :vomiting ;
    :hasTreatment :avoid_abrupt_head_movment,
        :avoid_sudden_change_in_body,
        :lie_down,
        :relax .

