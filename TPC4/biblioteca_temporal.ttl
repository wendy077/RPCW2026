#################################################################
#    Classes
#################################################################

###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Agente
:Agente rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Autor
:Autor rdf:type owl:Class ;
       rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Biblioteca
:Biblioteca rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Bibliotecario
:Bibliotecario rdf:type owl:Class ;
               rdfs:subClassOf :Pessoa ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :trabalhaEm ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Biblioteca
                               ] .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Emprestimo
:Emprestimo rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty :emLinhaTemporal ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :LinhaTemporal
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :temLeitor ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Leitor
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :temLivro ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Livro
                            ] .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#EntidadeTemporal
:EntidadeTemporal rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Evento
:Evento rdf:type owl:Class ;
        rdfs:subClassOf :EntidadeTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#EventoFuturo
:EventoFuturo rdf:type owl:Class ;
              rdfs:subClassOf :Evento ;
              owl:disjointWith :EventoHistorico .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#EventoHistorico
:EventoHistorico rdf:type owl:Class ;
                 rdfs:subClassOf :Evento .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Leitor
:Leitor rdf:type owl:Class ;
        rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LinhaAlternativa
:LinhaAlternativa rdf:type owl:Class ;
                  rdfs:subClassOf :LinhaTemporal ;
                  owl:disjointWith :LinhaOriginal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LinhaOriginal
:LinhaOriginal rdf:type owl:Class ;
               rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LinhaTemporal
:LinhaTemporal rdf:type owl:Class ;
               rdfs:subClassOf :EntidadeTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Livro
:Livro rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :existeEm ;
                         owl:someValuesFrom :LinhaTemporal
                       ] .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LivroFiccional
:LivroFiccional rdf:type owl:Class ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :refereEvento ;
                                  owl:allValuesFrom [
                                      rdf:type owl:Class ;
                                      owl:complementOf :EventoHistorico
                                  ]
                                ] ;
                owl:disjointWith :LivroHistorico .

###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LivroHistorico
:LivroHistorico rdf:type owl:Class ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :refereEvento ;
                                  owl:allValuesFrom :EventoHistorico
                                ] .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#LivroParadoxal
:LivroParadoxal rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Livro
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :existeEm ;
                                                             owl:someValuesFrom :LinhaAlternativa
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :existeEm ;
                                                             owl:someValuesFrom :LinhaOriginal
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :existeEm ;
                                  owl:someValuesFrom :LinhaAlternativa
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :existeEm ;
                                  owl:someValuesFrom :LinhaOriginal
                                ] .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Pessoa
:Pessoa rdf:type owl:Class ;
        rdfs:subClassOf :Agente .


