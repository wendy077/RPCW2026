###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Biblioteca_Entre_Ontem_e_Amanha
:Biblioteca_Entre_Ontem_e_Amanha rdf:type owl:NamedIndividual ,
                                          :Biblioteca .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Cronos
:Cronos rdf:type owl:NamedIndividual ,
                 :Autor ,
                 :Bibliotecario ;
        :trabalhaEm :Biblioteca_Entre_Ontem_e_Amanha .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Linha_T0
:Linha_T0 rdf:type owl:NamedIndividual ,
                   :LinhaOriginal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Linha_T1
:Linha_T1 rdf:type owl:NamedIndividual ,
                   :LinhaAlternativa .

###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Livro_Cronos_001
:Livro_Cronos_001 rdf:type owl:NamedIndividual , :LivroParadoxal ;
    :escritoPor :Cronos ;
    :pertenceA :Biblioteca_Entre_Ontem_e_Amanha ;
    :existeEm :Linha_T0 , :Linha_T1 ;
    :refereEvento :Crise_de_1929 .

###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#Crise_de_1929
:Crise_de_1929 rdf:type owl:NamedIndividual , :EventoHistorico .

