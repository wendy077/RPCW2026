#################################################################

###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#emLinhaTemporal
:emLinhaTemporal rdf:type owl:ObjectProperty ;
                 rdfs:domain :Emprestimo ;
                 rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#escritoPor
:escritoPor rdf:type owl:ObjectProperty ;
            owl:inverseOf :temAutor ;
            rdfs:domain :Livro ;
            rdfs:range :Autor .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#existeEm
:existeEm rdf:type owl:ObjectProperty ;
          rdfs:domain :Livro ;
          rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#ocorreEm
:ocorreEm rdf:type owl:ObjectProperty ;
          rdfs:domain :Evento ;
          rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#pertenceA
:pertenceA rdf:type owl:ObjectProperty ;
           rdfs:domain :Livro ;
           rdfs:range :Biblioteca .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#refereEvento
:refereEvento rdf:type owl:ObjectProperty ;
              rdfs:domain :Livro ;
              rdfs:range :Evento .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#requisita
:requisita rdf:type owl:ObjectProperty ;
           rdfs:domain :Leitor ;
           rdfs:range :Livro .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#temAutor
:temAutor rdf:type owl:ObjectProperty ;
          rdfs:domain :Autor ;
