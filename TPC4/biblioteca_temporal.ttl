           rdfs:range :Leitor .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#temLivro
:temLivro rdf:type owl:ObjectProperty ;
          rdfs:domain :Emprestimo ;
          rdfs:range :Livro .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#trabalhaEm
:trabalhaEm rdf:type owl:ObjectProperty ;
            rdfs:domain :Bibliotecario ;
            rdfs:range :Biblioteca .


