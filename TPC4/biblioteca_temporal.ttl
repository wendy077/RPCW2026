###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#temBibliotecario
:temBibliotecario rdf:type owl:ObjectProperty ;
                  owl:inverseOf :trabalhaEm ;
                  rdfs:domain :Biblioteca ;
                  rdfs:range :Bibliotecario .


###  http://rpcw.di.uminho.pt/2026/biblioteca-temporal#temLeitor
:temLeitor rdf:type owl:ObjectProperty ;
