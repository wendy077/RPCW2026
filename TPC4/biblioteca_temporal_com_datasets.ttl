:Emprestimo a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :LinhaTemporal ;
            owl:onProperty :emLinhaTemporal ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :Leitor ;
            owl:onProperty :temLeitor ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :Livro ;
            owl:onProperty :temLivro ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

