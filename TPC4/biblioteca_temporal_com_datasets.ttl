:nome a owl:DatatypeProperty ;
    rdfs:domain :Agente ;
    rdfs:range xsd:string .

:ocorreEm a owl:ObjectProperty ;
    rdfs:domain :Evento ;
    rdfs:range :LinhaTemporal .

